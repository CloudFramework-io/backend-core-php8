      },
      "GroupId": {
        "name": "Group",
        "type": "select",
        "external_values": "datastore",
        "entity": "CloudFrameWorkAcademyGroups",
        "fields": "GroupName",
        "linked_field": "KeyId",
        "id_field": "GroupId",
        "order": "Position ASC",
        "load_in_memory": true,
        "data_format": "{{GroupName}}"
      },
      "CourseOrder": {
        "name": "CourseOrder"
      },
      "CourseTitle": {
        "name": "Course Title",
        "cols": 3
      },
      "CourseLogo": {
        "name": "Course Logo",
        "allow_empty": true,
        "type": "public_image",
        "image": true,
        "image_height": 40,
        "bucket": "gs://cloudframework-public/images/{{Platform:namespace}}/academy-group-images"
      },
      "CourseTeacher": {
        "name": "Course Teacher",
        "type": "autocomplete",
        "external_values": "datastore",
        "entity": "CloudFrameWorkUsers",
        "fields": "KeyName,UserName,UserEmail,UserAvatar",
        "linked_field": "KeyName",
        "external_where": {
          "UserActive": true,
          "UserPrivileges": [
            "academy-teacher"
          ]
        },
        "allow_empty": true,
        "input_type": "users",
        "defaultvalue": "{{User:KeyName}}",
        "tab": "config"
      },
      "CourseDescription": {
        "name": "Course Description",
        "type": "html",
        "defaultvalue": "<h1>Title of the course</h1>\n<p>Welcome to this course about XXXXXX</p>",
        "allow_empty": true
      },
      "CourseMinPoints": {
        "name": "Min Points to Pass",
        "allow_empty": true,
        "tab": "config"
      },
      "CourseMaxTries": {
        "name": "Max Tries",
        "allow_empty": true,
        "tab": "config"
      },
      "CourseMaxTime": {
        "name": "Max Time (min)",
        "allow_empty": true,
        "tab": "config"
      },
      "Questions": {
        "name": "Course Questions",
        "type": "json",
        "tab": "config",
        "allow_empty": true,
        "defaultvalue": "{\n    \"Introducción: Qué tienes que tener instalado en tu ordenador\": {\n        \"title\": \"¿Qué tienes que tener instalado en tu ordenador para instalar CloudFramework API Test?\",\n        \"type\": \"checkbox|radio\",\n        \"category\": \"Introducción\",\n        \"points\": 1,\n        \"shuffle\": true,\n        \"answers\": [\n            {\n                \"title\": \"Un servidor de FTP\",\n                \"grade\": 0\n            },\n            {\n                \"title\": \"composer\",\n                \"grade\": 50\n            },\n            {\n                \"title\": \"php versión mínima 7.3\",\n                \"grade\": 50\n            },\n            {\n                \"title\": \"java 11\",\n                \"grade\": 0\n            }\n        ]\n    }\n}"
      },
      "Active": {
        "name": "Active",
        "type": "boolean",
        "defaultvalue": true
      },
      "CourseContents": {
        "field": "CourseContents",
        "name": "Virtual View of Course Contents",
        "type": "virtual",
        "external_info": "datastore",
        "external_order": "Position ASC",
        "linked_field": "CourseId",
        "field_value": "KeyId",
        "fields": "*",
        "entity": "CloudFrameWorkAcademyContents",
        "_order": "Position ASC",
        "summary_line": "[{{Position}}] {{ContentTitle}}",
        "external_new_entity_url": "/cfi/CloudFrameWorkAcademyContents/insert?filter_CourseId={{KeyId}}"
      },
      "UserGroups": {
        "name": "User Groups to give access (empty=all)",
        "type": "checkbox",
        "external_values": "datastore",
        "entity": "CloudFrameWorkGroups",
        "linked_field": "KeyName",
        "fields": "Title",
        "id_field": "UserGroups",
        "tab": "config",
        "load_in_memory": true,
        "data_format": "{{Title}}",
        "section_class": "col col-12",
        "allow_empty": true
      },
      "UsersToApply": {
        "field": "UsersToApply",
        "name": "Users to apply with the Users Groups",
        "type": "virtual",
        "external_info": "datastore",
        "linked_field": "UserGroups",
        "field_value": "UserGroups",
        "fields": "KeyName",
        "entity": "CloudFrameWorkUsers",
        "_order": "Position ASC",
        "summary_line": "{{KeyName}}",
        "tab": "config"
      },
      "DocumentationId": {
        "name": "Documentation Group",
        "type": "select",
        "external_values": "datastore",
        "entity": "CloudFrameWorkDevDocumentation",
        "fields": "KeyName,Title",
        "linked_field": "KeyName",
        "nowrap": true,
        "display_cfo": true,
        "cfo": "CloudFrameWorkDevDocumentation",
        "cols": 3,
        "allow_empty": true,
        "tab": "development"
      },
      "ExamsAndAccesses": {
        "field": "ExamsAndAccesses",
        "name": "Users with any answer",
        "type": "virtual",
        "external_info": "datastore",
        "entity": "CloudFrameWorkAcademyAnswers",
        "fields": "UserId,DateInsertion,DateUpdated,CourseMaxTries,CourseMaxTime,CoursePoints,CourseMinPoints,Points,Tries",
        "linked_field": "CourseId",
        "field_value": "KeyId",
        "_order": "Position ASC",
        "summary_line": "{{UserId}} tried [{{Tries}}] last updated [{{DateUpdated}}]",
        "tab": "answers"
      },
      "CopyContents": {
        "name": "Special Feature",
        "type": "virtual",
        "tab": "contents",
        "security": {
          "user_spacenames": [
            "cloudframework"
          ]
        },
        "external_apis": [
          {
            "title": "Copy Content to Other Platform",
            "url": "https://api.cloudframework.io/erp/lms/{{Platform:namespace}}/{{User:KeyName}}/cfo/copy-courses/{{KeyName}}"
          }
        ]
      },
      "_spacename": {
        "name": "Plataforma",
        "tab": "config"
      }
    },
